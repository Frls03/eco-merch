# Copia este archivo a ".env" y completa con los valores de tu proyecto de Supabase.
# Los encuentras en: Supabase Dashboard → Project Settings → API.
#
# IMPORTANTE: solo pon aquí la "anon public key". NUNCA la "service_role key"
# en este archivo ni en ningún código del frontend: esa clave tiene acceso
# total a la base de datos saltándose todas las reglas de seguridad (RLS).

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
